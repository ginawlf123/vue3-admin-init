# 自动检测文本文件并执行行尾标准化
* text=auto eol=lf

# 明确声明始终使用 LF 行尾的文件
*.sh text eol=lf

# 明确声明始终使用 CRLF 行尾的文件
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# 包管理器锁定文件
pnpm-lock.yaml text eol=lf
package-lock.json text eol=lf
yarn.lock text eol=lf
