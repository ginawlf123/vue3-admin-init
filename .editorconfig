# EditorConfig 配置文件
# 帮助不同编辑器和 IDE 保持一致的编码风格
# 详情: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
insert_final_newline = false

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 2

[*.{js,ts,jsx,tsx,vue}]
indent_size = 2

[*.{html,css,scss,sass}]
indent_size = 2
