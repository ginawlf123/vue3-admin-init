{
  "name": "vue3-admin-init",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "build:analyze": "vite build --mode analyze",
    "type-check": "vue-tsc --build",
    "type-check:watch": "vue-tsc --build --watch",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{js,ts,jsx,tsx,vue,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,jsx,tsx,vue,json,css,scss,md}\"",
    "clean": "rimraf dist node_modules/.vite node_modules/.tmp",
    "clean:cache": "rimraf node_modules/.vite node_modules/.tmp .eslintcache"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.13.6",
    "crypto-js": "^4.2.0",
    "element-plus": "^2.13.5",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/ep": "^1.2.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.11.0",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "fast-glob": "^3.3.3",
    "globals": "^17.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "0.18.5",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
